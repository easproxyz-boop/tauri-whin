{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tauri-whin",
  "version": "0.1.0",
  "identifier": "com.erwinaaquino.tauri-whin",

  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:web",
    "frontendDist": "../dist"
  },

  "app": {
    "windows": [
      {
        "label": "main",
        "title": "tauri-whin",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'; media-src 'self' blob: mediastream:; img-src 'self' data: blob:",
      "capabilities": ["default"]
    }
  },

  "bundle": {
    "active": true,
    "targets": "all",

    "macOS": {
      "entitlements": "entitlements.plist",
      "infoPlist": "Info.plist"
    },

    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}